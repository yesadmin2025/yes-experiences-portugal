{
  "ci": {
    "collect": {
      "startServerCommand": "bun run preview --port 4174",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://localhost:4174/",
        "http://localhost:4174/hero-verify",
        "http://localhost:4174/builder",
        "http://localhost:4174/experiences"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "mobile",
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 393,
          "height": 851,
          "deviceScaleFactor": 2.75,
          "disabled": false
        },
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4
        },
        "throttlingMethod": "simulate",
        "onlyCategories": ["performance", "accessibility", "best-practices"],
        "skipAudits": ["uses-http2", "canonical"],
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.45 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.8 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 1200 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 6500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 500 }],
        "max-potential-fid": ["warn", { "maxNumericValue": 500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
